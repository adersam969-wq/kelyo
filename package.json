{
  "name": "kelyo",
  "version": "0.1.0",
  "private": true,
  "description": "Kelyo - Unified payment wallet for Central Africa",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:backend": "npm run start:dev --workspace=@kelyo/backend",
    "dev:dashboard": "npm run dev --workspace=@kelyo/dashboard",
    "dev:mobile": "npm run start --workspace=@kelyo/mobile",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
