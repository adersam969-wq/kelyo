# Application
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1
APP_URL=http://localhost:3000

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=kelyo
DB_PASSWORD=kelyo_dev_password
DB_NAME=kelyo_dev
DB_LOGGING=false

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT (CHANGE IN PRODUCTION — use 64+ random bytes, base64)
JWT_ACCESS_SECRET=replace_me_with_strong_random_secret_at_least_64_chars_long
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace_me_with_another_strong_random_secret_64_chars_long
JWT_REFRESH_EXPIRES_IN=30d

# OTP
OTP_LENGTH=6
OTP_EXPIRES_IN_SECONDS=300
OTP_MAX_ATTEMPTS=5

# CinetPay (sandbox credentials — get from cinetpay.com dashboard)
CINETPAY_API_KEY=your_cinetpay_api_key
CINETPAY_SITE_ID=your_cinetpay_site_id
CINETPAY_SECRET_KEY=your_cinetpay_secret_key
CINETPAY_API_URL=https://api-checkout.cinetpay.com/v2/payment
CINETPAY_TRANSFER_API_URL=https://client.cinetpay.com/v1
CINETPAY_NOTIFY_URL=http://localhost:3000/api/v1/webhooks/cinetpay/payment
CINETPAY_RETURN_URL=http://localhost:3000/api/v1/webhooks/cinetpay/return
CINETPAY_MODE=TEST

# SMS provider (for OTP — placeholder for now, logs to console in dev)
SMS_PROVIDER=console
SMS_FROM=Kelyo

# Storage (MinIO local, S3 in prod)
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_ACCESS_KEY=kelyo_minio
STORAGE_SECRET_KEY=kelyo_minio_dev_password
STORAGE_BUCKET=kelyo-kyc
STORAGE_REGION=us-east-1

# Wallet limits (XAF — Central African CFA franc)
WALLET_MAX_BALANCE_TIER0=100000
WALLET_MAX_BALANCE_TIER1=500000
WALLET_MAX_BALANCE_TIER2=2000000
WALLET_DAILY_TX_LIMIT_TIER0=50000
WALLET_DAILY_TX_LIMIT_TIER1=300000
WALLET_DAILY_TX_LIMIT_TIER2=1500000

# CORS
CORS_ORIGINS=http://localhost:3001,http://localhost:19006,exp://

# Rate limiting
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100
